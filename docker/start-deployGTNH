#!/bin/bash

# shellcheck source=start-utils
. "$(dirname "${BASH_SOURCE[0]}")/start-utils"

# This is the upstream GTNH deploy flow with exact release and tested daily
# artifact support plus transactional updates for persistent servers.
CUSTOM_GTNH_RESOLVER_MARKER="custom-gtnh-resolver-20260720"
log "Using custom GTNH resolver override: ${CUSTOM_GTNH_RESOLVER_MARKER}"

GTNH_DAILY_REPOSITORY="${GTNH_DAILY_REPOSITORY:-GTNewHorizons/DreamAssemblerXXL}"
GTNH_DAILY_WORKFLOW="${GTNH_DAILY_WORKFLOW:-daily-modpack-build.yml}"
GTNH_GITHUB_API="${GTNH_GITHUB_API:-https://api.github.com}"
GTNH_UPDATE_MARKER="/data/.gtnh-update-in-progress"

function setGTNHdownloadPath(){
  gtnh_download_path="$1"
  gtnh_selected_id="${2:-$(basename "$gtnh_download_path")}"
  gtnh_download_kind="${3:-archive}"
  gtnh_download_sha256="${4:-${GTNH_PACK_SHA256:-}}"
  gtnh_download_size="${5:-}"
}

function isDailyGTNHpackVersion(){
  [[ "${GTNH_PACK_VERSION:-}" == "daily" ||
     "${GTNH_PACK_VERSION:-}" == "latest-daily" ||
     "${GTNH_PACK_VERSION:-}" =~ ^daily-[0-9]{4}-[0-9]{2}-[0-9]{2}\+[0-9]+$ ]]
}

function isExactDailyGTNHpackVersion(){
  [[ "${GTNH_PACK_VERSION:-}" =~ ^daily-[0-9]{4}-[0-9]{2}-[0-9]{2}\+[0-9]+$ ]]
}

function exactDailyGTNHversionMarker(){
  local java_release=""
  local java_variant=""
  java_release="$(mc-image-helper java-release)"
  if (( java_release == 8 )); then
    java_variant="server-java8"
  else
    java_variant="server-java17-25"
  fi
  printf 'GTNH-%s-%s.zip\n' "$GTNH_PACK_VERSION" "$java_variant"
}

function exactDailyGTNHisAlreadyInstalled(){
  isExactDailyGTNHpackVersion || return 1
  [[ -s /data/.gtnh-version ]] || return 1
  [[ "$(exactDailyGTNHversionMarker)" == "$(cat /data/.gtnh-version)" ]]
}

function hasGTNHgithubToken(){
  local xtrace_enabled="false"
  [[ $- == *x* ]] && xtrace_enabled="true" && set +x
  [[ -n "${GTNH_GITHUB_TOKEN:-}" ||
     (-n "${GTNH_GITHUB_TOKEN_FILE:-}" && -s "${GTNH_GITHUB_TOKEN_FILE}") ]]
  local status=$?
  isTrue "$xtrace_enabled" && set -x
  return "$status"
}

function githubApiCurl(){
  local xtrace_enabled="false"
  local github_token=""
  local status=0
  [[ $- == *x* ]] && xtrace_enabled="true" && set +x

  if [[ -n "${GTNH_GITHUB_TOKEN:-}" ]]; then
    github_token="$GTNH_GITHUB_TOKEN"
  elif [[ -n "${GTNH_GITHUB_TOKEN_FILE:-}" && -s "${GTNH_GITHUB_TOKEN_FILE}" ]]; then
    github_token="$(<"$GTNH_GITHUB_TOKEN_FILE")"
  fi

  if [[ -n "$github_token" ]]; then
    curl -fsSL \
      -H 'Accept: application/vnd.github+json' \
      -H 'X-GitHub-Api-Version: 2022-11-28' \
      -H "Authorization: Bearer $github_token" \
      "$@"
    status=$?
  else
    curl -fsSL \
      -H 'Accept: application/vnd.github+json' \
      -H 'X-GitHub-Api-Version: 2022-11-28' \
      "$@"
    status=$?
  fi

  github_token=""
  isTrue "$xtrace_enabled" && set -x
  return "$status"
}

function selectDailyGTNHpack(){
  local artifacts_url=""
  local artifacts_json=""
  local artifact=""
  local artifact_name=""
  local build_id=""
  local java_variant=""
  local run_json=""

  isDailyGTNHpackVersion || return 1

  if ! hasGTNHgithubToken; then
    logError "GTNH_GITHUB_TOKEN (or GTNH_GITHUB_TOKEN_FILE) is required to download GitHub Actions daily artifacts."
    logError "Use a read-only token with Actions access and store it as a secret in Coolify."
    exit 1
  fi

  if (( current_java_version == 8 )); then
    java_variant="server-java8"
  elif (( current_java_version >= 17 && current_java_version <= 25 )); then
    java_variant="server-java17-25"
  else
    logError "GTNH daily builds support Java 8 or Java 17-25; found Java $current_java_version."
    exit 1
  fi

  if [[ "$GTNH_PACK_VERSION" == "daily" || "$GTNH_PACK_VERSION" == "latest-daily" ]]; then
    log "Resolving the latest successful tested GTNH daily workflow run."
    if ! run_json="$(githubApiCurl \
        "$GTNH_GITHUB_API/repos/$GTNH_DAILY_REPOSITORY/actions/workflows/$GTNH_DAILY_WORKFLOW/runs?branch=master&status=success&per_page=10")"; then
      logError "Unable to retrieve GTNH daily workflow runs from GitHub."
      exit 1
    fi
    artifacts_url="$(jq -r '.workflow_runs | map(select(.conclusion == "success")) | first | .artifacts_url // empty' <<< "$run_json")"
    if [[ -z "$artifacts_url" ]]; then
      logError "No successful GTNH daily workflow run was found."
      exit 1
    fi
  else
    build_id="${GTNH_PACK_VERSION#daily-}"
    artifact_name="GTNH-daily-${build_id}-${java_variant}.zip"
    log "Resolving exact tested GTNH daily artifact $artifact_name."
    local encoded_artifact_name="${artifact_name//+/%2B}"
    artifacts_url="$GTNH_GITHUB_API/repos/$GTNH_DAILY_REPOSITORY/actions/artifacts?name=$encoded_artifact_name&per_page=100"
  fi

  if ! artifacts_json="$(githubApiCurl "$artifacts_url")"; then
    logError "Unable to retrieve GTNH daily artifact metadata from GitHub."
    exit 1
  fi

  if [[ -n "$artifact_name" ]]; then
    artifact="$(jq -c --arg name "$artifact_name" \
      '.artifacts | map(select(.name == $name and (.expired | not))) | sort_by(.created_at) | last // empty' \
      <<< "$artifacts_json")"
  else
    artifact="$(jq -c --arg suffix "-$java_variant.zip" \
      '.artifacts | map(select((.expired | not) and (.name | endswith($suffix)))) | sort_by(.created_at) | last // empty' \
      <<< "$artifacts_json")"
  fi

  if [[ -z "$artifact" ]]; then
    logError "The requested GTNH daily artifact was not found or has expired."
    logError "Choose a successful build still listed on the DreamAssemblerXXL Actions page."
    exit 1
  fi

  artifact_name="$(jq -r '.name' <<< "$artifact")"
  build_id="${artifact_name#GTNH-daily-}"
  build_id="${build_id%-"$java_variant".zip}"
  setGTNHdownloadPath \
    "$(jq -r '.archive_download_url' <<< "$artifact")" \
    "$artifact_name" \
    "github-actions" \
    "$(jq -r '.digest // empty' <<< "$artifact" | sed 's/^sha256://')" \
    "$(jq -r '.size_in_bytes // empty' <<< "$artifact")"
  log "Selected tested GTNH daily build $build_id for Java $current_java_version."
  return 0
}

function isExactGTNHpackVersion(){
  case "${GTNH_PACK_VERSION:-}" in
    ""|latest|latest-dev|http://*|https://*) return 1 ;;
    *) return 0 ;;
  esac
}

function validateGTNHdownloadUrl(){
  url="$1"

  curl -fsSLI "$url" >/dev/null 2>&1
}

function synthesizedGTNHdownloadUrl(){
  version="$1"

  if (( current_java_version == 8 )); then
    java_suffix="8"
  else
    java_suffix="17-${current_java_version}"
  fi

  pack_dir="ServerPacks"
  if [[ "$version" =~ (beta|[Rr][Cc]) ]]; then
    pack_dir="ServerPacks/betas"
  fi

  printf 'https://downloads.gtnewhorizons.com/%s/GT_New_Horizons_%s_Server_Java_%s.zip\n' \
    "$pack_dir" "$version" "$java_suffix"
}

function selectExplicitGTNHpackUrl(){
  if [[ -z "${GTNH_PACK_URL:-}" ]]; then
    return 1
  fi

  log "GTNH_PACK_URL is set; validating direct server archive URL."
  if validateGTNHdownloadUrl "$GTNH_PACK_URL"; then
    log "Validated direct GTNH server archive URL: $GTNH_PACK_URL"
    setGTNHdownloadPath "$GTNH_PACK_URL"
    return 0
  fi

  logError "GTNH_PACK_URL is set but does not point to a reachable archive: $GTNH_PACK_URL"
  exit 1
}

function selectSynthesizedGTNHpackUrl(){
  isExactGTNHpackVersion || return 1

  candidate_url="$(synthesizedGTNHdownloadUrl "$GTNH_PACK_VERSION")"
  log "No metadata match for GTNH_PACK_VERSION=$GTNH_PACK_VERSION; trying standard archive URL: $candidate_url"

  if validateGTNHdownloadUrl "$candidate_url"; then
    log "Validated synthesized GTNH server archive URL: $candidate_url"
    setGTNHdownloadPath "$candidate_url"
    return 0
  fi

  logWarning "Standard archive URL was not reachable for GTNH_PACK_VERSION=$GTNH_PACK_VERSION"
  return 1
}

function getGTNHdownloadPath(){
  local max_java_version=""
  local metadata_json=""
  local release_entry=""
  local release_key=""
  local server_url=""

  gtnh_download_path=""
  gtnh_selected_id=""
  gtnh_download_kind=""
  gtnh_download_sha256=""
  gtnh_download_size=""
  current_java_version=$(mc-image-helper java-release)

  if selectDailyGTNHpack; then
    return
  fi

  if selectExplicitGTNHpackUrl; then
    return
  fi

  if ! metadata_json="$(curl -fsSL "https://downloads.gtnewhorizons.com/versions.json")"; then
    logWarning "Failed to retrieve data from https://downloads.gtnewhorizons.com/versions.json"
    if selectSynthesizedGTNHpackUrl; then
      return
    fi
    logError "Download metadata is unavailable and no fallback archive URL could be selected."
    exit 1
  fi

  case "$GTNH_PACK_VERSION" in
    latest)
      release_entry="$(jq -c '(.versions // .) | to_entries | map(select(.value.title == "Stable release")) | sort_by(.value.releaseDate) | last // empty' <<< "$metadata_json")"
      ;;
    latest-dev)
      release_entry="$(jq -c '(.versions // .) | to_entries | map(select(.value.title == "Beta release")) | sort_by(.value.releaseDate) | last // empty' <<< "$metadata_json")"
      ;;
    *)
      release_entry="$(jq -c --arg version "$GTNH_PACK_VERSION" '(.versions // .) | to_entries | map(select(.key == $version)) | first // empty' <<< "$metadata_json")"
      ;;
  esac

  if [[ -n "$release_entry" ]]; then
    release_key="$(jq -r '.key' <<< "$release_entry")"
    max_java_version="$(jq -r '.value.maxJavaVersion // empty' <<< "$release_entry")"
    if (( current_java_version == 8 )); then
      server_url="$(jq -r '.value.server.java8Url // empty' <<< "$release_entry")"
    elif (( current_java_version >= 17 )); then
      if [[ -n "$max_java_version" ]] && (( current_java_version > max_java_version )); then
        logError "Container Java version $current_java_version is not supported by GTNH $release_key (maximum Java $max_java_version)."
        exit 1
      fi
      server_url="$(jq -r '.value.server.java17_2XUrl // empty' <<< "$release_entry")"
    fi

    if [[ -n "$server_url" ]]; then
      log "Selected official GTNH server release $release_key from versions.json."
      setGTNHdownloadPath "$server_url"
      return
    fi
  fi

  if [[ -z "$gtnh_download_path" ]]; then
    selectSynthesizedGTNHpackUrl || true
  fi
}

function deleteGTNHbackup(){
  log "Start deleting all GTNH transaction backups"
  if ! find /data -maxdepth 1 -type d -name 'gtnh-upgrade-*' -exec rm -rf {} + ; then
    logWarning "Can not delete config backup!"
  fi
}

function gtnhManagedResources(){
  printf '%s\n' \
    libraries mods resources scripts config journeymap \
    lwjgl3ify-forgePatches.jar java9args.txt \
    startserver-java9.bat startserver-java9.sh \
    forge-1.7.10-10.13.4.1614-1.7.10-universal.jar \
    minecraft_server.1.7.10.jar startserver.bat startserver.sh
}

function safeGTNHbuildId(){
  printf '%s' "$1" | tr -c 'A-Za-z0-9._+-' '_'
}

function selectedGTNHversionMarker(){
  printf '%s\n' "${gtnh_selected_id:-$(basename "$gtnh_download_path")}"
}

function writeGTNHversionMarker(){
  local marker_tmp="/data/.gtnh-version.tmp.$$"
  selectedGTNHversionMarker > "$marker_tmp"
  mv -f "$marker_tmp" /data/.gtnh-version
}

function validateGTNHarchive(){
  local candidate="$1"
  local config_count=""
  local library_count=""
  local min_configs="${GTNH_MIN_CONFIG_FILES:-500}"
  local min_libraries="${GTNH_MIN_LIBRARY_JARS:-20}"
  local min_mods="${GTNH_MIN_MOD_JARS:-150}"
  local mod_count=""
  local required_file=""
  local required_files=("forge-1.7.10-10.13.4.1614-1.7.10-universal.jar")

  if [[ ! -d "$candidate/config" || ! -d "$candidate/mods" || ! -d "$candidate/libraries" ]]; then
    logError "GTNH archive validation failed: config, mods, and libraries directories are required."
    return 1
  fi

  if (( current_java_version >= 17 )); then
    required_files+=("lwjgl3ify-forgePatches.jar" "java9args.txt" "startserver-java9.sh")
  fi
  for required_file in "${required_files[@]}"; do
    if [[ ! -s "$candidate/$required_file" ]]; then
      logError "GTNH archive validation failed: required runtime file is missing: $required_file"
      return 1
    fi
  done

  mod_count="$(find "$candidate/mods" -maxdepth 1 -type f -name '*.jar' | wc -l)"
  library_count="$(find "$candidate/libraries" -type f -name '*.jar' | wc -l)"
  config_count="$(find "$candidate/config" -type f | wc -l)"
  if (( mod_count < min_mods || library_count < min_libraries || config_count < min_configs )); then
    logError "GTNH archive validation failed: found $mod_count mod jars, $library_count library jars, and $config_count config files."
    logError "Expected at least $min_mods mod jars, $min_libraries library jars, and $min_configs config files."
    return 1
  fi

  if find "$candidate" -type l -print -quit | grep -q .; then
    logError "GTNH archive validation failed: symbolic links are not allowed in the server pack."
    return 1
  fi

  log "Validated complete GTNH server archive ($mod_count mods, $library_count libraries, $config_count config files)."
}

function downloadGTNH(){
  local actual_sha256=""
  local actual_size=""
  local gtnh_download=""
  local packs_dir="/data/.tmp/packs"

  original_base_dir="/data/.tmp/gtnh_base"
  base_dir="$original_base_dir"
  rm -rf "$original_base_dir" "$packs_dir"
  mkdir -p "$original_base_dir" "$packs_dir"

  if [[ "$gtnh_download_kind" == "github-actions" ]]; then
    gtnh_download="$packs_dir/$gtnh_selected_id"
    log "Downloading authenticated GTNH daily artifact $gtnh_selected_id."
    if ! githubApiCurl -o "$gtnh_download" "$gtnh_download_path"; then
      logError "Failed to download GTNH daily artifact. Check token permissions and artifact expiry."
      return 1
    fi
  else
    log "Downloading $gtnh_download_path."
    if ! gtnh_download=$(mc-image-helper get -o "$packs_dir" --output-filename --skip-up-to-date "$gtnh_download_path"); then
      logError "Failed to download $gtnh_download_path"
      return 1
    fi
  fi

  if [[ -n "$gtnh_download_size" ]]; then
    actual_size="$(stat -c '%s' "$gtnh_download")"
    if [[ "$actual_size" != "$gtnh_download_size" ]]; then
      logError "GTNH archive size verification failed: expected $gtnh_download_size bytes, got $actual_size."
      return 1
    fi
  fi

  if [[ -n "$gtnh_download_sha256" ]]; then
    actual_sha256="$(sha256sum "$gtnh_download" | awk '{print $1}')"
    if [[ "${actual_sha256,,}" != "${gtnh_download_sha256,,}" ]]; then
      logError "GTNH archive digest verification failed."
      return 1
    fi
    log "Verified GTNH archive SHA-256 digest."
  fi

  log "Unpacking GTNH server files into staging."
  if ! extract "$gtnh_download" "$original_base_dir"; then
    logError "Failed to extract GTNH server files."
    return 1
  fi
  rm -f "$gtnh_download"
  rm -f "$original_base_dir/eula.txt"

  if ! base_dir=$(mc-image-helper find \
      --max-depth=3 --type=directory --name=mods,config \
      --only-shallowest --fail-no-matches --format '%h' \
      "$original_base_dir"); then
    logError "Unable to find content base of downloaded GTNH server files."
    return 1
  fi

  validateGTNHarchive "$base_dir"
}

function rollbackGTNHupdate(){
  local backup_folder="$1"
  local failed="false"
  local old_state="$backup_folder/.old-resources"
  local resource=""
  local state=""

  if [[ ! -d "$backup_folder" || ! -f "$old_state" ]]; then
    logError "Cannot roll back interrupted GTNH update; transaction backup is missing: $backup_folder"
    return 1
  fi

  logWarning "Rolling back the incomplete GTNH pack update from $backup_folder."
  while IFS='|' read -r state resource; do
    [[ -n "$resource" ]] || continue
    if [[ "$state" == "absent" ]]; then
      if ! rm -rf "/data/$resource"; then
        failed="true"
      fi
    elif [[ -e "$backup_folder/$resource" ]]; then
      if ! rm -rf "/data/$resource" || ! mv "$backup_folder/$resource" "/data/$resource"; then
        failed="true"
      fi
    elif [[ "$state" != "present" ]]; then
      failed="true"
    fi
  done < "$old_state"

  if isTrue "$failed"; then
    logError "GTNH pack rollback did not complete; leaving $GTNH_UPDATE_MARKER in place for the next startup."
    return 1
  fi
  if ! rm -f "$GTNH_UPDATE_MARKER"; then
    logError "Rollback restored the GTNH pack, but the transaction marker could not be removed."
    return 1
  fi
  log "GTNH pack rollback completed; persistent game data was not changed."
}

function recoverInterruptedGTNHupdate(){
  local backup_folder=""
  [[ -f "$GTNH_UPDATE_MARKER" ]] || return 0

  backup_folder="$(head -n 1 "$GTNH_UPDATE_MARKER" | tr -d '\r\n')"
  case "$backup_folder" in
    /data/gtnh-upgrade-*) ;;
    *)
      logError "Invalid GTNH update transaction marker: $backup_folder"
      return 1
      ;;
  esac
  rollbackGTNHupdate "$backup_folder"
}

function createGTNHpreUpdateBackup(){
  local backup_dir="/backups"
  local backup_name=""
  local backup_path=""
  local current_datetime=""
  local current_id="unknown"
  local safe_current_id=""
  local safe_target_id=""
  local target_id=""
  local temp_path=""

  if isFalse "${GTNH_PRE_UPDATE_BACKUP:-true}"; then
    logWarning "GTNH_PRE_UPDATE_BACKUP is disabled; continuing without an exact pre-upgrade data archive."
    return 0
  fi
  if [[ ! -d "$backup_dir" || ! -w "$backup_dir" ]]; then
    logError "$backup_dir must be mounted read-write to create the required pre-upgrade backup."
    return 1
  fi

  current_datetime="$(date +%Y-%m-%dT%H%M%S)"
  [[ -s /data/.gtnh-version ]] && current_id="$(head -n 1 /data/.gtnh-version)"
  target_id="$(selectedGTNHversionMarker)"
  safe_current_id="$(safeGTNHbuildId "$current_id")"
  safe_target_id="$(safeGTNHbuildId "$target_id")"
  backup_name="gtnh-pre-upgrade-${safe_current_id}-to-${safe_target_id}-${current_datetime}.tar.gz"
  backup_path="$backup_dir/$backup_name"
  temp_path="$backup_dir/.${backup_name}.tmp.$$"

  log "Creating offline pre-upgrade data backup at $backup_path."
  if ! (
    set -o pipefail
    cd /data
    tar \
      --exclude='./.tmp' \
      --exclude='./backups' \
      --exclude='./cache' \
      --exclude='./logs' \
      --exclude='./packs' \
      --exclude='./gtnh-upgrade-*' \
      --exclude='./libraries' \
      --exclude='./mods' \
      --exclude='./journeymap' \
      --exclude='./*.jar' \
      -cf - . | gzip -1 > "$temp_path"
  ); then
    rm -f "$temp_path"
    logError "Failed to create the pre-upgrade GTNH data backup."
    return 1
  fi

  if ! gzip -t "$temp_path" || ! tar -tzf "$temp_path" >/dev/null; then
    rm -f "$temp_path"
    logError "Pre-upgrade GTNH data backup verification failed."
    return 1
  fi
  if ! mv "$temp_path" "$backup_path"; then
    rm -f "$temp_path"
    logError "Unable to commit the verified pre-upgrade GTNH data backup."
    return 1
  fi
  if ! date -u +%s > "$backup_dir/.last-verified.tmp.$$" ||
     ! mv "$backup_dir/.last-verified.tmp.$$" "$backup_dir/.last-verified"; then
    logWarning "Backup is valid, but the .last-verified health marker could not be updated."
  fi
  log "Verified offline pre-upgrade data backup: $backup_path"
}

function updateGTNH(){
  local backup_folder=""
  local changelog_file=""
  local current_datetime=""
  local current_id="unknown"
  local marker_tmp="${GTNH_UPDATE_MARKER}.tmp.$$"
  local old_state=""
  local resource=""
  local safe_current_id=""
  local safe_target_id=""
  local target_id=""
  local -a managed_resources=()

  if ! createGTNHpreUpdateBackup; then
    logError "Refusing to update GTNH without a verified pre-upgrade data backup."
    return 1
  fi

  mapfile -t managed_resources < <(gtnhManagedResources)
  current_datetime="$(date +%Y-%m-%dT%H%M%S)"
  [[ -s /data/.gtnh-version ]] && current_id="$(head -n 1 /data/.gtnh-version)"
  target_id="$(selectedGTNHversionMarker)"
  safe_current_id="$(safeGTNHbuildId "$current_id")"
  safe_target_id="$(safeGTNHbuildId "$target_id")"
  backup_folder="/data/gtnh-upgrade-${safe_current_id}-to-${safe_target_id}-${current_datetime}-$$"
  old_state="$backup_folder/.old-resources"

  if ! mkdir -p "$backup_folder"; then
    logError "Unable to create GTNH transaction backup: $backup_folder"
    return 1
  fi

  if ! : > "$old_state"; then
    logError "Unable to initialize GTNH transaction state: $old_state"
    return 1
  fi
  for resource in "${managed_resources[@]}"; do
    if [[ -e "/data/$resource" ]]; then
      if ! printf 'present|%s\n' "$resource" >> "$old_state"; then
        logError "Unable to record GTNH transaction state."
        return 1
      fi
    else
      if ! printf 'absent|%s\n' "$resource" >> "$old_state"; then
        logError "Unable to record GTNH transaction state."
        return 1
      fi
    fi
  done
  if ! printf '%s\n' "$backup_folder" > "$marker_tmp" || ! mv -f "$marker_tmp" "$GTNH_UPDATE_MARKER"; then
    logError "Unable to create the GTNH update transaction marker."
    rm -f "$marker_tmp"
    return 1
  fi

  log "Starting transactional GTNH pack update; rollback data is in $backup_folder."
  for resource in "${managed_resources[@]}"; do
    if [[ -e "/data/$resource" ]]; then
      if ! mv "/data/$resource" "$backup_folder/$resource"; then
        logError "Failed to stage existing GTNH resource for rollback: $resource"
        rollbackGTNHupdate "$backup_folder"
        return 1
      fi
    fi
  done

  for resource in "${managed_resources[@]}"; do
    if [[ -e "$base_dir/$resource" ]]; then
      if ! mv "$base_dir/$resource" "/data/$resource"; then
        logError "Failed to install staged GTNH resource: $resource"
        rollbackGTNHupdate "$backup_folder"
        return 1
      fi
    fi
  done

  if [[ -d "$backup_folder/config/JourneyMapServer" ]]; then
    log "Restoring persistent JourneyMapServer data."
    rm -rf /data/config/JourneyMapServer
    if ! cp -a "$backup_folder/config/JourneyMapServer" /data/config/; then
      logError "Failed to restore JourneyMapServer data."
      rollbackGTNHupdate "$backup_folder"
      return 1
    fi
  fi

  changelog_file="$(mc-image-helper find --max-depth=1 --type=file --name=changelog*.md "$base_dir" || true)"
  if [[ -n "$changelog_file" ]] && ! cp -f "$changelog_file" /data/; then
    logError "Failed to copy the GTNH changelog."
    rollbackGTNHupdate "$backup_folder"
    return 1
  fi

  if ! rm -f "$GTNH_UPDATE_MARKER"; then
    logError "Unable to commit the GTNH update transaction."
    rollbackGTNHupdate "$backup_folder"
    return 1
  fi
  log "Transactional GTNH pack update completed. Rollback snapshot retained at $backup_folder."
}

function hasExistingGTNHinstall(){
  [[ -d /data/mods || -d /data/config || -f /data/lwjgl3ify-forgePatches.jar || -f /data/forge-1.7.10-10.13.4.1614-1.7.10-universal.jar ]]
}

function installGTNH(){
  log "Installing validated GTNH server files without overwriting unrelated persistent data."
  cp -a -n "$base_dir/." /data/
}

function cleanupGTNHtemporaryFiles(){
  rm -rf /data/.tmp
}

function handleGTNH() {
  : "${GTNH_PACK_VERSION:=2.9.0-beta-2}"
  : "${GTNH_DELETE_BACKUPS:=false}"
  : "${SKIP_GTNH_UPDATE_CHECK:=false}"
  : "${GTNH_PACK_URL:=}"
  : "${GTNH_PACK_SHA256:=}"
  debug "GTNH VAR CHECK: GTNH_DELETE_BACKUPS=$GTNH_DELETE_BACKUPS, GTNH_PACK_VERSION=$GTNH_PACK_VERSION, GTNH_PACK_URL=$GTNH_PACK_URL, TYPE=$TYPE, SKIP_GTNH_UPDATE_CHECK=$SKIP_GTNH_UPDATE_CHECK"

  if ! recoverInterruptedGTNHupdate; then
    logError "Manual recovery is required before GTNH can start."
    exit 1
  fi

  if isTrue "$GTNH_DELETE_BACKUPS"; then
    deleteGTNHbackup
  fi

  if [[ -n $GTNH_PACK_VERSION ]] && isFalse "$SKIP_GTNH_UPDATE_CHECK" ; then
    if exactDailyGTNHisAlreadyInstalled; then
      log "No update required: the exact pinned daily build is already installed."
      return 0
    fi

    getGTNHdownloadPath

    if [[ -z $gtnh_download_path ]]; then
      logError "Server files not found for GTNH_PACK_VERSION=$GTNH_PACK_VERSION! Download not possible!"
      if [[ -z "$GTNH_PACK_URL" ]]; then
        logError "If this release exists but is missing from versions.json, set GTNH_PACK_URL to its direct server archive URL."
      fi
      exit 1
    fi
    local selected_marker=""
    selected_marker="$(selectedGTNHversionMarker)"
    log "Server files located: $selected_marker"

    if [[ ! -f /data/.gtnh-version || "$selected_marker" != "$(cat /data/.gtnh-version)" ]]; then
      log "Update/install required: selected build is $selected_marker."

      if ! downloadGTNH; then
        logError "GTNH download or preflight validation failed; /data was not changed."
        exit 1
      fi

      if hasExistingGTNHinstall; then
        log "Existing GTNH installation detected; applying transactional update."
        if ! updateGTNH; then
          logError "GTNH update failed and was rolled back."
          exit 1
        fi
      else
        log "No existing GTNH installation detected; installing new server."
        if ! installGTNH; then
          logError "GTNH installation failed."
          exit 1
        fi
      fi
      if ! writeGTNHversionMarker; then
        logError "GTNH files were installed, but the version marker could not be written."
        exit 1
      fi
      rm -rf "$original_base_dir"

    else
      log "No update required: /data/.gtnh-version matches $selected_marker."
    fi
  else
    log "SKIP_GTNH_UPDATE_CHECK=$SKIP_GTNH_UPDATE_CHECK ... Skipping GTNH Update/Install"
  fi
}

function setGTNHconfigValue() {
  local file="$1"
  local key="$2"
  local value="$3"

  if [[ ! -f "$file" ]]; then
    logWarning "Safety override skipped because config is missing: $file"
    return
  fi

  if ! grep -Eq "^[[:space:]]*$key=" "$file"; then
    logWarning "Safety override key is missing from $file: $key"
    return
  fi

  sed -i -E "s|^([[:space:]]*)$key=.*|\\1$key=$value|" "$file"
  log "Applied safety override $key=$value in $file"
}

function applyGTNHSafetyOverrides() {
  local hodgepodge="/data/config/hodgepodge.cfg"
  local serverutilities="/data/serverutilities/serverutilities.cfg"

  if isTrue "${GTNH_DISABLE_OPTIMIZED_CHUNK_COMPRESSION:-true}"; then
    setGTNHconfigValue "$hodgepodge" "B:speedupChunkCompression" "false"
    setGTNHconfigValue "$hodgepodge" "B:poolZlibInstances" "false"
  fi

  if isTrue "${GTNH_CHUNK_SAVE_DEBUG:-true}"; then
    setGTNHconfigValue "$hodgepodge" "B:chunkSaveCMEDebug" "true"
  fi

  setGTNHconfigValue "$serverutilities" "S:backup_timer" "${GTNH_INTERNAL_BACKUP_TIMER:-0.5}"
  setGTNHconfigValue "$serverutilities" "I:backups_to_keep" "${GTNH_INTERNAL_BACKUPS_TO_KEEP:-48}"
  setGTNHconfigValue "$serverutilities" "I:max_folder_size" "${GTNH_INTERNAL_BACKUP_MAX_GB:-35}"
  setGTNHconfigValue "$serverutilities" "I:compression_level" "${GTNH_INTERNAL_BACKUP_COMPRESSION:-4}"
  setGTNHconfigValue "$serverutilities" "B:only_backup_claimed_chunks" "${GTNH_INTERNAL_BACKUP_CLAIMED_ONLY:-true}"
  setGTNHconfigValue "$serverutilities" "B:backup_entire_regions_with_claims" "${GTNH_INTERNAL_BACKUP_WHOLE_REGIONS:-true}"
}

function main(){
  trap cleanupGTNHtemporaryFiles EXIT

  log "Applying GTNH optimized server defaults"
  export ALLOW_FLIGHT="${ALLOW_FLIGHT:=true}"
  export LEVEL_TYPE="${LEVEL_TYPE:=rwg}"
  export DIFFICULTY="${DIFFICULTY:=3}"
  export ENABLE_COMMAND_BLOCK="${ENABLE_COMMAND_BLOCK:=true}"
  export MOTD="${MOTD:="Greg Tech New Horizons $GTNH_PACK_VERSION"}"
  debug "Set MOTD=$MOTD, ENABLE_COMMAND_BLOCK=$ENABLE_COMMAND_BLOCK, DIFFICULTY=$DIFFICULTY, LEVEL_TYPE=$LEVEL_TYPE, ALLOW_FLIGHT=$ALLOW_FLIGHT"

  isDebugging && set -x

  ensureRemoveAllModsOff "MODPACK_PLATFORM=GTNH"

  java_version=$(mc-image-helper java-release)
  if (( java_version == 8 )); then
    export SERVER=/data/forge-1.7.10-10.13.4.1614-1.7.10-universal.jar
  elif (( java_version >= 17 )); then
    export SERVER=/data/lwjgl3ify-forgePatches.jar
  else
    logError "Greg Tech New Horizons only supports the following Java versions: 8, 17 or later"
    exit 1
  fi

  log "TYPE=GTNH, setting Minecraft version to 1.7.10"
  export VERSION=1.7.10

  handleGTNH
  applyGTNHSafetyOverrides

  export USES_MODS=true
  cleanupGTNHtemporaryFiles
  trap - EXIT
  exec "$(dirname "$0")/start-setupWorld" "$@"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
