# Coolify/Compose metadata
CONTAINER_NAME=gtnh
MC_IMAGE_TAG=java25
TZ=America/Santo_Domingo
UID=1000
GID=1000

# Network
MC_PORT=25565
SERVER_PORT=25565
ENABLE_QUERY=false
QUERY_PORT=25565
RCON_PORT=25575

# JVM and GTNH versioning
MEMORY=16G
GTNH_PACK_VERSION=latest
SKIP_GTNH_UPDATE_CHECK=false
GTNH_DELETE_BACKUPS=false

# Shutdown and recovery
STOP_GRACE_PERIOD=6m
STOP_DURATION=300
STOP_SERVER_ANNOUNCE_DELAY=0
JVM_OPTS=
JVM_DD_OPTS=fml.queryResult:cancel
AUTO_RESTORE_ON_CORRUPT_LEVELDAT=true
AUTO_RESTORE_ON_FML_LEVELDAT_WARNING=true
AUTO_RESTORE_BACKUP_DIRS=/backups /data/backups
AUTO_RESTORE_BACKUP_MAX_DEPTH=4

# RCON-coordinated backup sidecar
MC_BACKUP_IMAGE_TAG=latest
BACKUP_CONTAINER_NAME=gtnh-backups
BACKUP_NAME=gtnh
BACKUP_INTERVAL=2h
BACKUP_INITIAL_DELAY=0
PRUNE_BACKUPS_DAYS=14

# Server gameplay/admin settings
MAX_PLAYERS=10
MOTD=GregTech New Horizons
VIEW_DISTANCE=10
SIMULATION_DISTANCE=10
ONLINE_MODE=true
PVP=true
SPAWN_PROTECTION=0
DIFFICULTY=hard
ALLOW_FLIGHT=true
ENABLE_COMMAND_BLOCK=true
LEVEL_TYPE=rwg

# Access control
ENABLE_WHITELIST=true
ENFORCE_WHITELIST=true
OPS=
RCON_PASSWORD=change-me-before-deploying
