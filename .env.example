# Coolify/Compose metadata
CONTAINER_NAME=gtnh
MC_IMAGE_TAG=2026.5.3-java25
TZ=America/Santo_Domingo
MC_UID=1000
MC_GID=1000

# Network
MC_PORT=25565
SERVER_PORT=25565
ENABLE_QUERY=false
QUERY_PORT=25565
RCON_PORT=25575

# JVM and GTNH versioning
MEMORY=12G
GTNH_PACK_VERSION=2.9.0-beta-2
# Optional direct server archive URL for pinned versions missing from versions.json
GTNH_PACK_URL=
# Optional SHA-256 for GTNH_PACK_URL. Daily artifacts supply their digest automatically.
GTNH_PACK_SHA256=
# Required for daily builds. Store as a Coolify secret; needs read-only GitHub Actions access.
GTNH_GITHUB_TOKEN=
# Creates and verifies an incremental world/player/admin snapshot before each pack update.
GTNH_PRE_UPDATE_BACKUP=true
# Restic always uses /backups/restic. Only configure the password as a long Coolify secret.
GTNH_RESTIC_PASSWORD=
GTNH_RESTIC_HOSTNAME=gtnh
GTNH_RESTIC_RETRY_LOCK=5m
GTNH_RESTIC_READ_CONCURRENCY=4
GTNH_RESTIC_PROGRESS_SECONDS=10
GTNH_RESTIC_COMPRESSION=auto
GTNH_PRE_UPDATE_SNAPSHOTS_KEEP=2
# Keep this many verified server artifacts in the persistent digest cache.
GTNH_ARTIFACT_CACHE_KEEP=2
# Keep the latest managed-file rollback directories and reserve disk before snapshots.
GTNH_TRANSACTION_BACKUPS_KEEP=2
GTNH_BACKUP_MIN_FREE_GB=20
SKIP_GTNH_UPDATE_CHECK=false

# Shutdown and recovery
STOP_GRACE_PERIOD=10m
STOP_DURATION=540
STOP_SERVER_ANNOUNCE_DELAY=0
JVM_OPTS=
JVM_DD_OPTS=
AUTO_CONFIRM_FORGE_QUERIES=false
GTNH_INTERNAL_BACKUP_TIMER=0.5
GTNH_INTERNAL_BACKUPS_TO_KEEP=24
GTNH_INTERNAL_BACKUP_MAX_GB=20
GTNH_INTERNAL_BACKUP_COMPRESSION=4
GTNH_INTERNAL_BACKUP_CLAIMED_ONLY=true
GTNH_INTERNAL_BACKUP_WHOLE_REGIONS=true

# RCON-coordinated backup sidecar
MC_BACKUP_IMAGE_TAG=2026.7.1
BACKUP_CONTAINER_NAME=gtnh-backups
BACKUP_NAME=gtnh
BACKUP_INTERVAL=12h
BACKUP_INITIAL_DELAY=0
PRUNE_RESTIC_RETENTION=--keep-within 24h --keep-daily 7 --keep-weekly 4 --keep-monthly 3
BACKUP_EXCLUDES=*.jar,cache,logs,*.tmp,backups,.gtnh-manager,.gtnh-recovery,gtnh-upgrade-*,World-*.zip,packs

# Server gameplay/admin settings
MAX_PLAYERS=10
MOTD=GregTech New Horizons
VIEW_DISTANCE=10
SIMULATION_DISTANCE=10
ONLINE_MODE=true
PVP=true
SPAWN_PROTECTION=0
DIFFICULTY=hard
ALLOW_FLIGHT=true
ENABLE_COMMAND_BLOCK=true
LEVEL_TYPE=rwg

# Access control
ENABLE_WHITELIST=true
ENFORCE_WHITELIST=true
OPS=
