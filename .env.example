# Coolify/Compose metadata
CONTAINER_NAME=gtnh
MC_IMAGE_TAG=2026.5.3-java25
TZ=America/Santo_Domingo
MC_UID=1000
MC_GID=1000

# Network
MC_PORT=25565
SERVER_PORT=25565
ENABLE_QUERY=false
QUERY_PORT=25565
RCON_PORT=25575

# JVM and GTNH versioning
MEMORY=12G
GTNH_PACK_VERSION=2.9.0-beta-2
# Optional direct server archive URL for pinned versions missing from versions.json
GTNH_PACK_URL=
SKIP_GTNH_UPDATE_CHECK=false
GTNH_DELETE_BACKUPS=false

# Shutdown and recovery
STOP_GRACE_PERIOD=10m
STOP_DURATION=540
STOP_SERVER_ANNOUNCE_DELAY=0
JVM_OPTS=
JVM_DD_OPTS=
AUTO_CONFIRM_FORGE_QUERIES=false
AUTO_RESTORE_ON_CORRUPT_LEVELDAT=false
AUTO_RESTORE_ON_FML_LEVELDAT_WARNING=false
AUTO_RESTORE_BACKUP_DIRS=/backups /data/backups
AUTO_RESTORE_BACKUP_MAX_DEPTH=4
CORRUPTION_GUARD_ENABLED=true
CORRUPTION_GUARD_CLEAR=false
GTNH_DISABLE_OPTIMIZED_CHUNK_COMPRESSION=true
GTNH_CHUNK_SAVE_DEBUG=true
GTNH_INTERNAL_BACKUP_TIMER=0.5
GTNH_INTERNAL_BACKUPS_TO_KEEP=48
GTNH_INTERNAL_BACKUP_MAX_GB=35
GTNH_INTERNAL_BACKUP_COMPRESSION=4
GTNH_INTERNAL_BACKUP_CLAIMED_ONLY=true
GTNH_INTERNAL_BACKUP_WHOLE_REGIONS=true

# RCON-coordinated backup sidecar
MC_BACKUP_IMAGE_TAG=2026.7.1
BACKUP_CONTAINER_NAME=gtnh-backups
BACKUP_NAME=gtnh
BACKUP_INTERVAL=12h
BACKUP_INITIAL_DELAY=0
PRUNE_BACKUPS_DAYS=7
PRUNE_BACKUPS_COUNT=14
BACKUP_EXCLUDES=*.jar,cache,logs,*.tmp,backups,.gtnh-recovery,gtnh-upgrade-*,World-*.zip,packs

# Server gameplay/admin settings
MAX_PLAYERS=10
MOTD=GregTech New Horizons
VIEW_DISTANCE=10
SIMULATION_DISTANCE=10
ONLINE_MODE=true
PVP=true
SPAWN_PROTECTION=0
DIFFICULTY=hard
ALLOW_FLIGHT=true
ENABLE_COMMAND_BLOCK=true
LEVEL_TYPE=rwg

# Access control
ENABLE_WHITELIST=true
ENFORCE_WHITELIST=true
OPS=
